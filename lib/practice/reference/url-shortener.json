{
  "slug": "url-shortener",
  "title": "URL Shortener",
  "nonFunctional": {
    "categories": [
      {
        "id": "latency",
        "label": "Latency",
        "description": "How quickly should the system respond to redirect requests?",
        "examples": [
          "Redirects should be fast (under 100ms)",
          "Sub-second response time for URL lookups",
          "Minimize latency for good user experience"
        ],
        "quantitative": {
          "min": 10,
          "max": 500,
          "recommended": 100,
          "unit": "ms",
          "metric": "P95 latency for redirect operations"
        }
      },
      {
        "id": "readThroughput",
        "label": "Read Throughput",
        "description": "How many redirect requests should the system handle per second?",
        "examples": [
          "Support high read volume (thousands of redirects per second)",
          "Handle viral content spikes",
          "Read-heavy workload optimization"
        ],
        "quantitative": {
          "min": 100,
          "max": 100000,
          "recommended": 5000,
          "unit": "rps",
          "metric": "Read requests per second (redirects)"
        }
      },
      {
        "id": "writeThroughput",
        "label": "Write Throughput",
        "description": "How many URL creation requests should the system handle per second?",
        "examples": [
          "Support moderate write volume",
          "100+ URL creations per second",
          "Lower write volume compared to reads"
        ],
        "quantitative": {
          "min": 10,
          "max": 10000,
          "recommended": 100,
          "unit": "rps",
          "metric": "Write requests per second (URL creation)"
        }
      },
      {
        "id": "availability",
        "label": "Availability",
        "description": "How reliable should the system be? What level of downtime is acceptable?",
        "examples": [
          "High availability with minimal downtime",
          "99.9% uptime (about 8 hours downtime per year)",
          "Critical service requiring redundancy"
        ],
        "quantitative": {
          "acceptable": ["99.0", "99.9", "99.99"],
          "recommended": "99.9"
        }
      },
      {
        "id": "scalability",
        "label": "Scalability",
        "description": "How should the system scale as traffic grows?",
        "examples": [
          "Horizontal scaling for increased load",
          "Auto-scale based on traffic patterns",
          "Handle 10x traffic spikes during viral events"
        ]
      },
      {
        "id": "consistency",
        "label": "Consistency",
        "description": "What are the consistency requirements?",
        "examples": [
          "Eventual consistency acceptable for analytics",
          "Strong consistency for URL creation to prevent duplicates",
          "Read-after-write consistency for immediate redirects"
        ]
      }
    ]
  },
  "apiEndpoints": [
    {
      "method": "POST",
      "path": "/api/v1/urls",
      "purpose": "Create a new shortened URL",
      "required": true,
      "requestBody": {
        "url": {
          "type": "string",
          "required": true,
          "description": "The original long URL to shorten"
        },
        "customAlias": {
          "type": "string",
          "required": false,
          "description": "Optional custom alias for the short code"
        },
        "expiresAt": {
          "type": "timestamp",
          "required": false,
          "description": "Optional expiration timestamp in ISO 8601"
        }
      },
      "responses": {
        "201": {
          "description": "URL created successfully",
          "body": {
            "shortUrl": "string",
            "code": "string",
            "longUrl": "string",
            "createdAt": "timestamp",
            "expiresAt": "timestamp|null"
          }
        },
        "400": "Invalid URL or invalid custom alias",
        "409": "Custom alias already taken",
        "429": "Rate limit exceeded"
      }
    },
    {
      "method": "GET",
      "path": "/:code",
      "purpose": "Redirect to the original URL",
      "required": true,
      "responses": {
        "302": "Redirect to original URL",
        "404": "Code not found",
        "410": "Code expired"
      }
    },
    {
      "method": "GET",
      "path": "/api/v1/urls/:code/stats",
      "purpose": "Get analytics for a shortened URL",
      "required": false,
      "requiresFeature": "basic-analytics",
      "responses": {
        "200": {
          "description": "Analytics data",
          "body": {
            "code": "string",
            "clickCount": "number",
            "createdAt": "timestamp",
            "lastAccessedAt": "timestamp|null"
          }
        },
        "404": "Code not found"
      }
    },
    {
      "method": "PATCH",
      "path": "/api/v1/urls/:code",
      "purpose": "Update link metadata",
      "required": false,
      "requiresFeature": "link-metadata",
      "requestBody": {
        "url": {
          "type": "string",
          "required": false,
          "description": "Replace the destination URL"
        },
        "expiresAt": {
          "type": "timestamp",
          "required": false,
          "description": "Set or clear expiration"
        },
        "active": {
          "type": "boolean",
          "required": false,
          "description": "Soft disable or enable the link"
        }
      },
      "responses": {
        "200": {
          "description": "Link updated",
          "body": {
            "code": "string",
            "longUrl": "string",
            "active": "boolean",
            "expiresAt": "timestamp|null",
            "updatedAt": "timestamp"
          }
        },
        "400": "Invalid field values",
        "401": "Unauthorized",
        "404": "Code not found"
      }
    },
    {
      "method": "DELETE",
      "path": "/api/v1/urls/:code",
      "purpose": "Delete a shortened URL",
      "required": false,
      "requiresFeature": "admin-delete",
      "responses": {
        "204": "URL deleted successfully",
        "401": "Unauthorized",
        "404": "Code not found"
      }
    },
    {
      "method": "POST",
      "path": "/internal/v1/analytics/hit",
      "purpose": "Record a click for analytics in a decoupled service",
      "required": false,
      "requiresFeature": "analytics-pipeline",
      "requestBody": {
        "code": {
          "type": "string",
          "required": true,
          "description": "Short code that was accessed"
        },
        "ts": {
          "type": "timestamp",
          "required": true,
          "description": "Event timestamp"
        },
        "ua": {
          "type": "string",
          "required": false,
          "description": "User agent"
        },
        "ipHash": {
          "type": "string",
          "required": false,
          "description": "Hashed IP for privacy safe uniques"
        }
      },
      "responses": {
        "202": "Accepted for processing",
        "400": "Malformed payload",
        "401": "Unauthorized"
      }
    },
    {
      "method": "GET",
      "path": "/health",
      "purpose": "Liveness probe",
      "required": false,
      "responses": {
        "200": "Service is up"
      }
    },
    {
      "method": "GET",
      "path": "/ready",
      "purpose": "Readiness probe",
      "required": false,
      "responses": {
        "200": "Service is ready",
        "503": "Dependencies not ready"
      }
    }
  ],
  "components": {
    "base": ["Web", "API Gateway", "Service", "DB (Postgres)", "Cache (Redis)"],
    "analytics": ["Message Queue (Kafka Topic)", "Worker Pool"],
    "rateLimit": ["Rate Limiter"],
    "admin": ["Auth"],
    "optional": ["Load Balancer", "CDN", "Object Store (S3)", "Tracing/Logging"]
  }
}
