{
  "slug": "url-shortener",
  "title": "URL Shortener",
  "functional": {
    "required": [
      {
        "id": "url-shortening",
        "label": "URL shortening",
        "description": "System must accept long URLs and generate short codes/slugs",
        "keywords": ["shorten", "generate", "slug", "code", "short url", "create"]
      },
      {
        "id": "redirect",
        "label": "Redirect by slug",
        "description": "System must redirect users from short URL to original URL",
        "keywords": ["redirect", "lookup", "resolve", "navigate", "forward"]
      },
      {
        "id": "persistence",
        "label": "Persistent storage",
        "description": "URL mappings must be stored persistently in a database",
        "keywords": ["store", "save", "database", "persist", "storage"]
      }
    ],
    "optional": [
      {
        "id": "custom-aliases",
        "label": "Custom aliases",
        "description": "Users can choose their own custom short codes instead of auto-generated ones",
        "keywords": ["custom", "alias", "vanity", "personalized", "choose slug"]
      },
      {
        "id": "basic-analytics",
        "label": "Click analytics",
        "description": "Track click counts, timestamps, and basic metrics for each short URL",
        "keywords": ["analytics", "track", "count", "clicks", "metrics", "statistics", "monitor"]
      },
      {
        "id": "rate-limiting",
        "label": "Rate limiting",
        "description": "Prevent abuse by limiting requests per IP address or user account",
        "keywords": ["rate limit", "throttle", "abuse", "spam", "quota", "limit"]
      },
      {
        "id": "admin-delete",
        "label": "Admin deletion",
        "description": "Administrators can delete malicious, spam, or inappropriate URLs",
        "keywords": ["admin", "delete", "remove", "moderate", "manage"]
      }
    ]
  },
  "nonFunctional": {
    "categories": [
      {
        "id": "latency",
        "label": "Latency",
        "description": "How quickly should the system respond to redirect requests?",
        "examples": [
          "Redirects should be fast (under 100ms)",
          "Sub-second response time for URL lookups",
          "Minimize latency for good user experience"
        ],
        "quantitative": {
          "min": 10,
          "max": 500,
          "recommended": 100,
          "unit": "ms",
          "metric": "P95 latency for redirect operations"
        }
      },
      {
        "id": "readThroughput",
        "label": "Read Throughput",
        "description": "How many redirect requests should the system handle per second?",
        "examples": [
          "Support high read volume (thousands of redirects per second)",
          "Handle viral content spikes",
          "Read-heavy workload optimization"
        ],
        "quantitative": {
          "min": 100,
          "max": 100000,
          "recommended": 5000,
          "unit": "rps",
          "metric": "Read requests per second (redirects)"
        }
      },
      {
        "id": "writeThroughput",
        "label": "Write Throughput",
        "description": "How many URL creation requests should the system handle per second?",
        "examples": [
          "Support moderate write volume",
          "100+ URL creations per second",
          "Lower write volume compared to reads"
        ],
        "quantitative": {
          "min": 10,
          "max": 10000,
          "recommended": 100,
          "unit": "rps",
          "metric": "Write requests per second (URL creation)"
        }
      },
      {
        "id": "availability",
        "label": "Availability",
        "description": "How reliable should the system be? What level of downtime is acceptable?",
        "examples": [
          "High availability with minimal downtime",
          "99.9% uptime (about 8 hours downtime per year)",
          "Critical service requiring redundancy"
        ],
        "quantitative": {
          "acceptable": ["99.0", "99.9", "99.99"],
          "recommended": "99.9"
        }
      },
      {
        "id": "scalability",
        "label": "Scalability",
        "description": "How should the system scale as traffic grows?",
        "examples": [
          "Horizontal scaling for increased load",
          "Auto-scale based on traffic patterns",
          "Handle 10x traffic spikes during viral events"
        ]
      },
      {
        "id": "consistency",
        "label": "Consistency",
        "description": "What are the consistency requirements?",
        "examples": [
          "Eventual consistency acceptable for analytics",
          "Strong consistency for URL creation to prevent duplicates",
          "Read-after-write consistency for immediate redirects"
        ]
      }
    ]
  },
  "apiEndpoints": [
    {
      "method": "POST",
      "path": "/urls",
      "purpose": "Create a new shortened URL",
      "required": true,
      "requestBody": {
        "longUrl": {
          "type": "string",
          "required": true,
          "description": "The original long URL to shorten"
        },
        "customSlug": {
          "type": "string",
          "required": false,
          "description": "Optional custom slug (if custom-aliases feature is enabled)"
        }
      },
      "responses": {
        "201": {
          "description": "URL created successfully",
          "body": {
            "shortUrl": "string",
            "slug": "string",
            "longUrl": "string"
          }
        },
        "400": "Invalid URL or slug already taken",
        "429": "Rate limit exceeded (if rate-limiting enabled)"
      }
    },
    {
      "method": "GET",
      "path": "/:slug",
      "purpose": "Redirect to the original URL",
      "required": true,
      "responses": {
        "302": "Redirect to original URL",
        "404": "Slug not found"
      }
    },
    {
      "method": "GET",
      "path": "/urls/:slug/stats",
      "purpose": "Get analytics for a shortened URL",
      "required": false,
      "requiresFeature": "basic-analytics",
      "responses": {
        "200": {
          "description": "Analytics data",
          "body": {
            "slug": "string",
            "clickCount": "number",
            "createdAt": "timestamp",
            "lastAccessedAt": "timestamp"
          }
        },
        "404": "Slug not found"
      }
    },
    {
      "method": "DELETE",
      "path": "/urls/:slug",
      "purpose": "Delete a shortened URL (admin only)",
      "required": false,
      "requiresFeature": "admin-delete",
      "responses": {
        "204": "URL deleted successfully",
        "401": "Unauthorized - admin access required",
        "404": "Slug not found"
      }
    }
  ],
  "components": {
    "base": ["Web", "API Gateway", "Service", "DB (Postgres)", "Cache (Redis)"],
    "analytics": ["Message Queue (Kafka Topic)", "Worker Pool"],
    "rateLimit": ["Rate Limiter"],
    "admin": ["Auth"],
    "optional": ["Load Balancer", "CDN", "Object Store (S3)", "Tracing/Logging"]
  }
}
