# OpenAI API Key (required for speech to text)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: Enable Web Speech API fallback (Chrome only)
# Set to 1 to enable the browser's built-in speech recognition as a fallback
# Default is disabled (uses OpenAI Realtime only)
NEXT_PUBLIC_ENABLE_WEB_SPEECH=0

# Optional: Use direct Whisper API instead of Realtime API
# Set to 1 to use the simpler, faster Whisper API (no interim transcripts)
# Set to 0 to use the OpenAI Realtime API (supports interim transcripts, but slower startup)
# Default is 0 (Realtime API for backward compatibility)
NEXT_PUBLIC_USE_WHISPER_DIRECT=0
