{
  "name": "system-design-sandbox",
  "version": "0.1.0",
  "author": "Antonio Coppe",
  "private": true,
  "scripts": {
    "dev": "./scripts/with-local-postgres.sh node scripts/fix-util.js next dev --turbopack",
    "dev:remote": "node scripts/fix-util.js next dev --turbopack",
    "build": "node scripts/fix-util.js next build",
    "start": "node scripts/fix-util.js next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "./scripts/test-integration.sh",
    "test:integration:ci": "./scripts/run-integration-tests.sh",
    "test:watch": "vitest",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "generate-icons": "node scripts/generate-icons.js",
    "seed": "./scripts/with-local-postgres.sh npx tsx packages/seed.ts",
    "seed:remote": "npx tsx packages/seed.ts",
    "db:migrate": "./scripts/with-local-postgres.sh npx tsx scripts/run-migrations.ts",
    "db:migrate:remote": "npx tsx scripts/run-migrations.ts",
    "db:setup": "npm run db:migrate && npm run seed -- --force",
    "db:setup:remote": "npm run db:migrate:remote && npm run seed:remote -- --force",
    "db:local:up": "docker compose -f docker-compose.dev.yml up -d --wait",
    "db:local:down": "docker compose -f docker-compose.dev.yml down",
    "db:local:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "prepare": "husky",
    "pre-push:check": "concurrently --kill-others-on-fail \"npm:test\" \"npm:lint\" \"npm:typecheck\"",
    "pre-push": "npm run build && npm run pre-push:check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --cache --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,css}": [
      "prettier --cache --write"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.5",
    "@google/genai": "^1.42.0",
    "@posthog/ai": "^7.9.3",
    "@posthog/nextjs-config": "^1.7.6",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.6",
    "@react-email/render": "^2.0.1",
    "@supabase/supabase-js": "^2.74.0",
    "@xyflow/react": "^12.8.6",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "pako": "^2.1.0",
    "postgres": "^3.4.7",
    "posthog-js": "^1.354.3",
    "posthog-node": "^5.26.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-email": "^4.3.0",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.1.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.6",
    "@types/pako": "^2.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.6",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.6.2",
    "sharp": "^0.34.4",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^6.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
